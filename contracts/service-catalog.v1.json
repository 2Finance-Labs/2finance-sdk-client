{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.2finance.dev/sdk/service-catalog.v1.json",
  "title": "2Finance SDK service catalog",
  "type": "object",
  "required": ["services"],
  "properties": {
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "env"],
        "properties": {
          "name": { "type": "string" },
          "env": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
