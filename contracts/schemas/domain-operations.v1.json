{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.2finance.dev/sdk/domain-operations.v1.json",
  "title": "2Finance SDK domain operations",
  "type": "object",
  "required": ["schema", "domains"],
  "properties": {
    "schema": {
      "const": "sdk.domain_operations.v1"
    },
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "env", "operations"],
        "properties": {
          "name": { "type": "string" },
          "env": { "type": "string" },
          "transport": {
            "type": "string",
            "enum": ["http", "jsonrpc", "websocket"]
          },
          "description": { "type": "string" },
          "operations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "method", "path"],
              "properties": {
                "name": { "type": "string" },
                "method": { "type": "string" },
                "path": { "type": "string" },
                "path_params": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "query": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "request_schema": { "type": "string" },
                "response_schema": { "type": "string" },
                "notes": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
