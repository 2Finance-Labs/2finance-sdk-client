{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.2finance.dev/sdk/service-catalog.v1.json",
  "title": "2Finance SDK Service Catalog",
  "type": "object",
  "required": ["services"],
  "additionalProperties": false,
  "properties": {
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "env"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "env": {
            "type": "string",
            "pattern": "^TWO_FINANCE_[A-Z0-9_]+$"
          }
        }
      }
    }
  }
}
