<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>com.twofinance</groupId>
  <artifactId>sdk-client</artifactId>
  <version>0.1.0-SNAPSHOT</version>
  <packaging>jar</packaging>

  <name>2finance-sdk-client-java</name>
  <description>Unified Java client for 2Finance services.</description>
  <url>https://github.com/2Finance-Labs/2finance-sdk-client</url>

  <licenses>
    <license>
      <name>MIT License</name>
      <url>https://opensource.org/license/mit</url>
      <distribution>repo</distribution>
    </license>
  </licenses>

  <developers>
    <developer>
      <organization>2Finance Labs</organization>
      <organizationUrl>https://github.com/2Finance-Labs</organizationUrl>
    </developer>
  </developers>

  <scm>
    <connection>scm:git:git://github.com/2Finance-Labs/2finance-sdk-client.git</connection>
    <developerConnection>scm:git:ssh://github.com/2Finance-Labs/2finance-sdk-client.git</developerConnection>
    <url>https://github.com/2Finance-Labs/2finance-sdk-client</url>
  </scm>

  <properties>
    <maven.compiler.release>11</maven.compiler.release>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
  </properties>
</project>
